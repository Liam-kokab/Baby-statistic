  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "From": {
        "name": "from",
        "in": "query",
        "required": false,
        "description": "Filter by created_at >= value (ISO datetime)",
        "schema": { "type": "string", "format": "date-time", "example": "2026-04-13T00:00:00" }
      },
      "To": {
        "name": "to",
        "in": "query",
        "required": false,
        "description": "Filter by created_at <= value (ISO datetime)",
        "schema": { "type": "string", "format": "date-time", "example": "2026-04-13T23:59:59" }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Conflict": {
        "description": "Conflict — record is in a terminal state",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid access token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated but not permitted (e.g. admin-only route)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "PingResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "pong" }
        },
        "required": ["message"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "admin"] },
          "babyId": { "type": "integer", "nullable": true },
          "config": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "username", "name", "role", "babyId", "config", "createdAt"]
      },
      "Baby": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "createdAt"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["username", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        },
        "required": ["accessToken", "refreshToken", "user"]
      },
      "RefreshRequest": {
        "type": "object",
        "properties": {
          "refreshToken": { "type": "string" }
        },
        "required": ["refreshToken"]
      },
      "RefreshResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" }
        },
        "required": ["accessToken", "refreshToken"]
      },
      "AdminCreateUser": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "admin"] },
          "babyId": { "type": "integer", "nullable": true },
          "name": { "type": "string" }
        },
        "required": ["username", "password", "role"]
      },
      "AdminCreateBaby": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "Timestamps": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "createdAt"]
      },
      "ServedMilk": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "example": 80 },
              "originalAmount": { "type": "integer", "example": 80 },
              "status": { "type": "string", "enum": ["FRIDGE", "FREEZER", "USED", "EXPIRED"], "example": "FRIDGE" },
              "expiryDate": { "type": "string", "format": "date-time", "nullable": true, "example": "2026-04-18T10:00:00.000Z" }
            },
            "required": ["amount", "originalAmount", "status", "expiryDate"]
          }
        ]
      },
      "ServedMilkPost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 80 },
          "status": { "type": "string", "enum": ["FRIDGE", "FREEZER"], "example": "FRIDGE" },
          "originalAmount": { "type": "integer", "example": 80 },
          "expiryDate": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["amount", "status"]
      },
      "ServedMilkTotal": {
        "type": "object",
        "properties": {
          "fridge":  { "type": "integer", "example": 1200 },
          "freezer": { "type": "integer", "example": 800 },
          "total":   { "type": "integer", "example": 2000 }
        },
        "required": ["fridge", "freezer", "total"]
      },
      "DrankMilk": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "example": 60 },
              "source": { "type": "string", "enum": ["FRIDGE", "FREEZER", "BOOB"], "example": "FRIDGE" }
            },
            "required": ["amount", "source"]
          }
        ]
      },
      "DrankMilkPost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 60 },
          "source": { "type": "string", "enum": ["FRIDGE", "FREEZER", "BOOB"], "example": "FRIDGE" },
          "isNewBottle": { "type": "boolean", "description": "true = create new record; false = add amount to latest existing record", "example": true },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["amount", "source", "isNewBottle"]
      },
      "WastePost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 10 }
        },
        "required": ["amount"]
      },
      "Sleep": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time", "example": "2026-04-13T22:00:00" },
              "end": { "type": "string", "format": "date-time", "nullable": true, "example": "2026-04-14T06:00:00" }
            },
            "required": ["start", "end"]
          }
        ]
      },
      "SleepPost": {
        "type": "object",
        "properties": {
          "start": { "type": "string", "format": "date-time", "example": "2026-04-13T22:00:00" },
          "end": { "type": "string", "format": "date-time", "nullable": true, "example": null }
        },
        "required": ["start"]
      },
      "SleepPut": {
        "type": "object",
        "properties": {
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Event": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" }
        ]
      },
      "EventPut": {
        "type": "object",
        "properties": {
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-14T12:00:00" }
        }
      },
      "BackupResponse": {
        "type": "object",
        "description": "Raw DB rows (snake_case columns) per table — as returned by GET /api/backup and accepted by POST /api/backup/restore.",
        "properties": {
          "served_milk":  { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "drank_milk":   { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "sleep":        { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "pee":          { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "poop":         { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "medicine":     { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "medicine_log": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "pumping":      { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        }
      },
      "Medicine": {
        "type": "object",
        "properties": {
          "id":            { "type": "integer" },
          "name":          { "type": "string", "example": "Vitamin D" },
          "isActive":      { "type": "boolean" },
          "latestTakenAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt":     { "type": "string", "format": "date-time" }
        }
      },
      "MedicinePost": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Vitamin D" }
        },
        "required": ["name"]
      },
      "MedicineLog": {
        "type": "object",
        "properties": {
          "id":         { "type": "integer" },
          "medicineId": { "type": "integer" },
          "takenAt":    { "type": "string", "format": "date-time" },
          "createdAt":  { "type": "string", "format": "date-time" }
        }
      },
      "MedicineLogPost": {
        "type": "object",
        "properties": {
          "takenAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      }
    }
  }
}

