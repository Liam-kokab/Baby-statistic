{
  "openapi": "3.0.3",
  "info": {
    "title": "Baby Statistic API",
    "description": "REST API for tracking baby milk, sleep, pee, and poop events.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local dev" }
  ],
  "tags": [
    { "name": "Ping" },
    { "name": "Build Time" },
    { "name": "Backup" },
    { "name": "Served Milk" },
    { "name": "Drank Milk" },
    { "name": "Sleep" },
    { "name": "Pee" },
    { "name": "Poop" },
    { "name": "Medicine" }
  ],
  "paths": {
    "/api/ping": {
      "get": {
        "tags": ["Ping"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PingResponse" }
              }
            }
          }
        }
      }
    },
    "/api/build-time": {
      "get": {
        "tags": ["Build Time"],
        "summary": "Get server build timestamp",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "buildTime": { "type": "string", "example": "2026-05-22T12:00:00.000Z" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/backup": {
      "get": {
        "tags": ["Backup"],
        "summary": "Day data backup",
        "description": "Returns all records created on the specified day (based on `created_at`). Defaults to yesterday if no date is provided.",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": false,
            "description": "Day to back up (DD-MM-YYYY). Defaults to yesterday.",
            "schema": { "type": "string", "example": "13-04-2026" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BackupResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/served-milk": {
      "get": {
        "tags": ["Served Milk"],
        "summary": "List all served milk records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ServedMilk" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Served Milk"],
        "summary": "Create a served milk record",
        "description": "status must be FRIDGE or FREEZER. expiryDate is auto-set (FRIDGE +4 days, FREEZER +6 months). originalAmount is auto-set to amount.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ServedMilkPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/served-milk/total": {
      "get": {
        "tags": ["Served Milk"],
        "summary": "Get total saved milk by location (no time filter)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilkTotal" }
              }
            }
          }
        }
      }
    },
    "/api/served-milk/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Served Milk"],
        "summary": "Get a served milk record by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Served Milk"],
        "summary": "Update a served milk record",
        "description": "Returns 409 if the record status is already USED or EXPIRED.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ServedMilkPost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      },
      "delete": {
        "tags": ["Served Milk"],
        "summary": "Delete a served milk record",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/drank-milk": {
      "get": {
        "tags": ["Drank Milk"],
        "summary": "List all drank milk records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DrankMilk" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Drank Milk"],
        "summary": "Create a drank milk record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DrankMilkPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/drank-milk/waste": {
      "post": {
        "tags": ["Drank Milk"],
        "summary": "Subtract waste from the latest drank milk record",
        "description": "Reduces the latest drank_milk record's amount by the given value (floored at 0). Does NOT touch served_milk (storage).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WastePost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK — updated drank milk record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/drank-milk/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Drank Milk"],
        "summary": "Get a drank milk record by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Drank Milk"],
        "summary": "Update a drank milk record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DrankMilkPost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Drank Milk"],
        "summary": "Delete a drank milk record",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/sleep": {
      "get": {
        "tags": ["Sleep"],
        "summary": "List all sleep records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Sleep" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Sleep"],
        "summary": "Create a sleep record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SleepPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sleep" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
      "/api/sleep/latest": {
      "get": {
        "tags": ["Sleep"],
        "summary": "Get the most recent sleep record",
        "description": "Returns the single sleep record with the latest `start` value, or `null` if none exist.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/Sleep" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/sleep/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Sleep"],
        "summary": "Get a sleep record by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sleep" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Sleep"],
        "summary": "Update a sleep record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SleepPut" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sleep" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Sleep"],
        "summary": "Delete a sleep record",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/pee": {
      "get": {
        "tags": ["Pee"],
        "summary": "List all pee events",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Pee"],
        "summary": "Log a pee event",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/api/pee/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Pee"],
        "summary": "Get a pee event by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Pee"],
        "summary": "Update a pee event timestamp",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EventPut" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Pee"],
        "summary": "Delete a pee event",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/poop": {
      "get": {
        "tags": ["Poop"],
        "summary": "List all poop events",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Poop"],
        "summary": "Log a poop event",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          }
        }
      }
    },
    "/api/poop/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Poop"],
        "summary": "Get a poop event by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Poop"],
        "summary": "Update a poop event timestamp",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EventPut" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Event" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Poop"],
        "summary": "Delete a poop event",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/medicine": {
      "get": {
        "tags": ["Medicine"],
        "summary": "List active medicines with latest log",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Medicine" } } } }
          }
        }
      },
      "post": {
        "tags": ["Medicine"],
        "summary": "Create a medicine",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MedicinePost" } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Medicine" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/medicine/logs": {
      "get": {
        "tags": ["Medicine"],
        "summary": "List medicine log entries",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/MedicineLog" } } } }
          }
        }
      }
    },
    "/api/medicine/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "delete": {
        "tags": ["Medicine"],
        "summary": "Soft-delete a medicine (logs retained)",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/medicine/{id}/log": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "post": {
        "tags": ["Medicine"],
        "summary": "Log a dose taken",
        "requestBody": {
          "required": false,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MedicineLogPost" } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MedicineLog" } } }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "From": {
        "name": "from",
        "in": "query",
        "required": false,
        "description": "Filter by created_at >= value (ISO datetime)",
        "schema": { "type": "string", "format": "date-time", "example": "2026-04-13T00:00:00" }
      },
      "To": {
        "name": "to",
        "in": "query",
        "required": false,
        "description": "Filter by created_at <= value (ISO datetime)",
        "schema": { "type": "string", "format": "date-time", "example": "2026-04-13T23:59:59" }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Conflict": {
        "description": "Conflict — record is in a terminal state",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "PingResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "pong" }
        },
        "required": ["message"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "Timestamps": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "createdAt"]
      },
      "ServedMilk": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "example": 80 },
              "originalAmount": { "type": "integer", "example": 80 },
              "status": { "type": "string", "enum": ["FRIDGE", "FREEZER", "USED", "EXPIRED"], "example": "FRIDGE" },
              "expiryDate": { "type": "string", "format": "date-time", "nullable": true, "example": "2026-04-18T10:00:00.000Z" }
            },
            "required": ["amount", "originalAmount", "status", "expiryDate"]
          }
        ]
      },
      "ServedMilkPost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 80 },
          "status": { "type": "string", "enum": ["FRIDGE", "FREEZER"], "example": "FRIDGE" },
          "originalAmount": { "type": "integer", "example": 80 },
          "expiryDate": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["amount", "status"]
      },
      "ServedMilkTotal": {
        "type": "object",
        "properties": {
          "fridge":  { "type": "integer", "example": 1200 },
          "freezer": { "type": "integer", "example": 800 },
          "total":   { "type": "integer", "example": 2000 }
        },
        "required": ["fridge", "freezer", "total"]
      },
      "DrankMilk": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "amount": { "type": "integer", "example": 60 },
              "source": { "type": "string", "enum": ["FRIDGE", "FREEZER", "BOOB"], "example": "FRIDGE" }
            },
            "required": ["amount", "source"]
          }
        ]
      },
      "DrankMilkPost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 60 },
          "source": { "type": "string", "enum": ["FRIDGE", "FREEZER", "BOOB"], "example": "FRIDGE" },
          "isNewBottle": { "type": "boolean", "description": "true = create new record; false = add amount to latest existing record", "example": true },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["amount", "source", "isNewBottle"]
      },
      "WastePost": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer", "example": 10 }
        },
        "required": ["amount"]
      },
      "Sleep": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" },
          {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time", "example": "2026-04-13T22:00:00" },
              "end": { "type": "string", "format": "date-time", "nullable": true, "example": "2026-04-14T06:00:00" }
            },
            "required": ["start", "end"]
          }
        ]
      },
      "SleepPost": {
        "type": "object",
        "properties": {
          "start": { "type": "string", "format": "date-time", "example": "2026-04-13T22:00:00" },
          "end": { "type": "string", "format": "date-time", "nullable": true, "example": null }
        },
        "required": ["start"]
      },
      "SleepPut": {
        "type": "object",
        "properties": {
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Event": {
        "allOf": [
          { "$ref": "#/components/schemas/Timestamps" }
        ]
      },
      "EventPut": {
        "type": "object",
        "properties": {
          "createdAt": { "type": "string", "format": "date-time", "example": "2026-04-14T12:00:00" }
        }
      },
      "BackupResponse": {
        "type": "object",
        "properties": {
          "date":       { "type": "string", "example": "2026-04-13" },
          "servedMilk": { "type": "array", "items": { "$ref": "#/components/schemas/ServedMilk" } },
          "drankMilk":  { "type": "array", "items": { "$ref": "#/components/schemas/DrankMilk" } },
          "sleep":      { "type": "array", "items": { "$ref": "#/components/schemas/Sleep" } },
          "pee":        { "type": "array", "items": { "$ref": "#/components/schemas/Event" } },
          "poop":       { "type": "array", "items": { "$ref": "#/components/schemas/Event" } }
        },
        "required": ["date", "servedMilk", "drankMilk", "sleep", "pee", "poop"]
      },
      "Medicine": {
        "type": "object",
        "properties": {
          "id":            { "type": "integer" },
          "name":          { "type": "string", "example": "Vitamin D" },
          "isActive":      { "type": "boolean" },
          "latestTakenAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt":     { "type": "string", "format": "date-time" }
        }
      },
      "MedicinePost": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Vitamin D" }
        },
        "required": ["name"]
      },
      "MedicineLog": {
        "type": "object",
        "properties": {
          "id":         { "type": "integer" },
          "medicineId": { "type": "integer" },
          "takenAt":    { "type": "string", "format": "date-time" },
          "createdAt":  { "type": "string", "format": "date-time" }
        }
      },
      "MedicineLogPost": {
        "type": "object",
        "properties": {
          "takenAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      }
    }
  }
}

