{
  "openapi": "3.0.3",
  "info": {
    "title": "Baby Statistic API",
    "description": "REST API for tracking baby milk, sleep, pee, and poop events.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local dev" }
  ],
  "tags": [
    { "name": "Ping" },
    { "name": "Auth" },
    { "name": "Admin" },
    { "name": "Baby" },
    { "name": "Build Time" },
    { "name": "Backup" },
    { "name": "Served Milk" },
    { "name": "Drank Milk" },
    { "name": "Sleep" },
    { "name": "Pee" },
    { "name": "Poop" },
    { "name": "Medicine" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with username + password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Exchange a refresh token for a new access + refresh token pair",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RefreshRequest" } } }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RefreshResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Invalidate a refresh token",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RefreshRequest" } } }
        },
        "responses": {
          "204": { "description": "No content" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the current authenticated user",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "tags": ["Auth"],
        "summary": "Update the current user's display name",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } } }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/admin/babies": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all babies (admin only)",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Baby" } } } }
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Create a baby (admin only)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminCreateBaby" } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Baby" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/admin/babies/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "put": {
        "tags": ["Admin"],
        "summary": "Rename a baby (admin only)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminCreateBaby" } } }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Baby" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete a baby (admin only)",
        "responses": {
          "204": { "description": "No content" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all users (admin only)",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } }
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Create a user (admin only)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminCreateUser" } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "description": "Username already taken" }
        }
      }
    },
    "/api/admin/users/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "patch": {
        "tags": ["Admin"],
        "summary": "Update a user's password, babyId, or name (admin only)",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string" },
                  "babyId": { "type": "integer", "nullable": true },
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete a user (admin only)",
        "responses": {
          "204": { "description": "No content" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/baby": {
      "get": {
        "tags": ["Baby"],
        "summary": "Get the current user's baby info and co-users",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "baby": { "$ref": "#/components/schemas/Baby" },
                    "users": { "type": "array", "items": { "$ref": "#/components/schemas/User" } }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/baby/name": {
      "patch": {
        "tags": ["Baby"],
        "summary": "Rename the current user's baby",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } } }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Baby" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/baby/invite": {
      "post": {
        "tags": ["Baby"],
        "summary": "Invite another user (by username) to share the current user's baby",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "username": { "type": "string" } }, "required": ["username"] } } }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "ok": { "type": "boolean" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/ping": {
      "get": {
        "tags": ["Ping"],
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PingResponse" }
              }
            }
          }
        }
      }
    },
    "/api/build-time": {
      "get": {
        "tags": ["Build Time"],
        "summary": "Get server build timestamp",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "buildTime": { "type": "string", "example": "2026-05-22T12:00:00.000Z" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/backup": {
      "get": {
        "tags": ["Backup"],
        "summary": "Full database dump (admin only)",
        "description": "Returns every row from every data table, as raw DB rows (snake_case columns), across all babies.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BackupResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/backup/restore": {
      "post": {
        "tags": ["Backup"],
        "summary": "Restore (upsert) rows into the DB (admin only)",
        "description": "Body may omit any table or individual fields — missing tables are skipped, missing nullable fields default to null. Body size limit is 20mb (raised from the default 100kb since a full-database dump can exceed it).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BackupResponse" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "inserted": { "type": "object", "additionalProperties": { "type": "integer" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/backup/purge": {
      "delete": {
        "tags": ["Backup"],
        "summary": "Irreversibly delete ALL data (admin only, requires recent login)",
        "description": "Deletes every row from every data table (served_milk, drank_milk, sleep, pee, poop, medicine, medicine_log, pumping, prediction_log) across all babies, and resets their auto-increment sequences. Does not touch babies, users, baby_users, or refresh_tokens. Requires the caller's access token to have an authTime (set only at login, never renewed by /api/auth/refresh) no older than 5 minutes — see doc/auth.md.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "confirm": { "type": "string", "example": "PURGE" } },
                "required": ["confirm"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "deleted": { "type": "object", "additionalProperties": { "type": "integer" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": {
            "description": "Forbidden — either not an admin, or the token's login is older than 5 minutes (REAUTH_REQUIRED)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/served-milk": {
      "get": {
        "tags": ["Served Milk"],
        "summary": "List all served milk records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ServedMilk" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Served Milk"],
        "summary": "Create a served milk record",
        "description": "status must be FRIDGE or FREEZER. expiryDate is auto-set (FRIDGE +4 days, FREEZER +6 months). originalAmount is auto-set to amount.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ServedMilkPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/served-milk/total": {
      "get": {
        "tags": ["Served Milk"],
        "summary": "Get total saved milk by location (no time filter)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilkTotal" }
              }
            }
          }
        }
      }
    },
    "/api/served-milk/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Served Milk"],
        "summary": "Get a served milk record by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Served Milk"],
        "summary": "Update a served milk record",
        "description": "Returns 409 if the record status is already USED or EXPIRED.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ServedMilkPost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServedMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      },
      "delete": {
        "tags": ["Served Milk"],
        "summary": "Delete a served milk record",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/drank-milk": {
      "get": {
        "tags": ["Drank Milk"],
        "summary": "List all drank milk records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DrankMilk" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Drank Milk"],
        "summary": "Create a drank milk record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DrankMilkPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/drank-milk/waste": {
      "post": {
        "tags": ["Drank Milk"],
        "summary": "Subtract waste from the latest drank milk record",
        "description": "Reduces the latest drank_milk record's amount by the given value (floored at 0). Does NOT touch served_milk (storage).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WastePost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK — updated drank milk record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/drank-milk/suggested": {
      "get": {
        "tags": ["Drank Milk"],
        "summary": "Get suggested next bottle amount",
        "description": "Returns a suggested millilitre amount for the next bottle based on server-side settings (default lookback 35 days).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nextDrinkAmount": { "type": "integer", "example": 60 }
                  },
                  "required": ["nextDrinkAmount"]
                }
              }
            }
          }
        }
      }
    },
    "/api/predictions": {
      "get": {
        "tags": ["Drank Milk"],
        "summary": "List stored prediction logs",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "integer" },
                      "predictedAmount": { "type": "integer" },
                      "actualId": { "type": "integer" },
                      "createdAt": { "type": "string", "format": "date-time" },
                      "rawPrediction": { "type": "number", "nullable": true },
                      "observedMax": { "type": "integer", "nullable": true },
                      "recencyFactor": { "type": "number", "nullable": true },
                      "roundingStep": { "type": "integer", "nullable": true }
                    },
                    "required": ["id","predictedAmount","actualId","createdAt"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/predictions/latest": {
      "get": {
        "tags": ["Drank Milk"],
        "summary": "Get the most recent stored prediction",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "predictedAmount": { "type": "integer" },
                        "actualId": { "type": "integer" },
                        "createdAt": { "type": "string", "format": "date-time" },
                        "rawPrediction": { "type": "number", "nullable": true },
                        "observedMax": { "type": "integer", "nullable": true },
                        "recencyFactor": { "type": "number", "nullable": true },
                        "roundingStep": { "type": "integer", "nullable": true }
                      },
                      "required": ["id","predictedAmount","actualId","createdAt"]
                    },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/drank-milk/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/Id" }],
      "get": {
        "tags": ["Drank Milk"],
        "summary": "Get a drank milk record by ID",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Drank Milk"],
        "summary": "Update a drank milk record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DrankMilkPost" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DrankMilk" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Drank Milk"],
        "summary": "Delete a drank milk record",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/sleep": {
      "get": {
        "tags": ["Sleep"],
        "summary": "List all sleep records",
        "parameters": [
          { "$ref": "#/components/parameters/From" },
          { "$ref": "#/components/parameters/To" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Sleep" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Sleep"],
        "summary": "Create a sleep record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SleepPost" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sleep" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
      "/api/sleep/latest": {
      "get": {
        "tags": ["Sleep"],
        "summary": "Get the most recent sleep record",
        "description": "Returns the single sleep record with the latest `start` value, or `null` if none exist.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/Sleep" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    },
