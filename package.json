{
  "name": "baby-statistic",
  "private": true,
  "workspaces": [
    "common",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "docker build -t baby-statistic",
    "build:local": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run build -w client && npm run build -w server",
    "start": "node scripts/docker-run.js",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
