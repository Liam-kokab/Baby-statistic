{
  "name": "baby-statistic-mcp-server",
  "private": true,
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const p='../dist/mcp-server/tools';fs.mkdirSync(p,{recursive:true});fs.writeFileSync(p+'/buildTime.json',JSON.stringify({buildTime:new Date().toISOString()}))\"",
    "predev": "node -e \"const fs=require('fs');fs.writeFileSync('src/tools/buildTime.json',JSON.stringify({buildTime:new Date().toISOString()}))\"",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node ../dist/mcp-server/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2"
  }
}
